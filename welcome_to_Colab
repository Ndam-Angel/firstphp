        "### Task 2: Preprocess the Data\n",
        "\n",
        "This step involves handling missing values, converting data types, encoding categorical variables, splitting the data into training and testing sets, handling class imbalance using SMOTE, and scaling numerical features. We'll specifically convert 'TotalCharges' to numeric and then encode other categorical features."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 1000
        },
        "id": "a0c768e2",
        "outputId": "d7cf0f4f-48aa-4163-cecd-b1b5d2ad2880"
      },
      "source": [
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
        "from imblearn.over_sampling import SMOTE\n",
        "import numpy as np\n",
        "\n",
        "# 1. Handle 'TotalCharges' column\n",
        "# Replace empty strings with NaN and convert to numeric\n",
        "df['TotalCharges'] = df['TotalCharges'].replace(' ', np.nan).astype(float)\n",
        "\n",
        "# Drop rows with NaN values (introduced by TotalCharges conversion)\n",
        "df.dropna(inplace=True)\n",
        "\n",
        "# Drop 'customerID' as it's an identifier and not a feature for modeling\n",
        "df.drop('customerID', axis=1, inplace=True)\n",
        "\n",
        "# 2. Convert target variable 'Churn' to numerical (0 and 1)\n",
        "df['Churn'] = df['Churn'].map({'Yes': 1, 'No': 0})\n",
        "\n",
        "# 3. Encode categorical variables using LabelEncoder\n",
        "# Convert all object columns to string type first to avoid TypeError with mixed types\n",
        "le = LabelEncoder()\n",
        "for col in df.select_dtypes(include=['object']).columns:\n",
        "    df[col] = df[col].astype(str)\n",
        "    df[col] = le.fit_transform(df[col])\n",
        "\n",
        "print(\"Data types after preprocessing and encoding:\")\n",
        "display(df.head())\n",
        "df.info()\n",
        "\n",
        "# 4. Define features (X) and target (y)\n",
        "X = df.drop('Churn', axis=1)\n",
        "y = df['Churn']\n",
        "\n",
        "# 5. Split the data into training and testing sets\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y, test_size=0.2, stratify=y, random_state=42\n",
        ")\n",
        "print(f\"\\nShape of X_train: {X_train.shape}, y_train: {y_train.shape}\")\n",
        "print(f\"Shape of X_test: {X_test.shape}, y_test: {y_test.shape}\")\n",
        "\n",
        "# 6. Handle class imbalance in the training set using SMOTE\n",
        "smote = SMOTE(random_state=42)\n",
        "X_res, y_res = smote.fit_resample(X_train, y_train)\n",
        "print(f\"\\nShape of X_res (after SMOTE): {X_res.shape}, y_res: {y_res.shape}\")\n",
        "print(\"Resampled Churn distribution:\")\n",
        "display(y_res.value_counts())\n",
        "\n",
        "# 7. Scale numerical features\n",
        "scaler = StandardScaler()\n",
        "X_res_scaled = scaler.fit_transform(X_res)\n",
        "X_test_scaled = scaler.transform(X_test)\n",
        "print(\"\\nNumerical features scaled.\")"
      ],
